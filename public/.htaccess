RewriteEngine On

# Bloque tous les .php sauf index.php
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

<Files "index.php">
    Require all granted
</Files>

# Front Controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

DirectorySlash Off

# Fichiers sensibles
<FilesMatch "^\.env|^.ht">
    Require all denied
</FilesMatch>
<FilesMatch "^\.sql">
    Order allow,deny
    Deny from all
</FilesMatch>
